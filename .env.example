# Token du bot Discord (obligatoire)
DISCORD_TOKEN=

# ID du serveur Discord principal (obligatoire)
GUILD_ID=

# Mode dev (true/false) — en dev, les slash commands sont enregistrées
# sur le seul serveur GUILD_ID (instantané), sinon globalement (1h de délai)
DEV_MODE=true

# Chemin absolu vers members.json
# - En local : laisser vide (utilise ./data/members.json par défaut)
# - Sur Render avec Persistent Disk monté sur /data : MEMBERS_FILE_PATH=/data/members.json
MEMBERS_FILE_PATH=

# Chemin absolu vers alts.json (généré par /import-alts)
# - Sur Render : ALTS_FILE_PATH=/data/alts.json
ALTS_FILE_PATH=

# Chemin absolu vers guild-info.json (infos Raider.io, fetch auto toutes les 24h)
# - Sur Render : GUILD_INFO_FILE_PATH=/data/guild-info.json
GUILD_INFO_FILE_PATH=
